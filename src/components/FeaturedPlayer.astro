---
import { Image } from 'astro:assets';
import type { Track } from '../data/tracks';

export interface Props {
  track: Track;
}

const { track } = Astro.props;
const playerUrl = `https://w.soundcloud.com/player/?url=${encodeURIComponent(track.url)}&color=%2378ba48&auto_play=true&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=true`;
---

<section class="featured-player" aria-labelledby="featured-track-title">
  <div class="player-artwork">
    <Image src={track.artwork} alt={`Artwork for ${track.title}`} width="500" height="500" loading="eager" fetchpriority="high" />
    <span aria-hidden="true">LATEST / 01</span>
  </div>
  <div class="player-copy">
    <p class="eyebrow">Latest upload</p>
    <h1 id="featured-track-title">{track.title}</h1>
    <p class="track-meta">{track.format} · {track.genre} · {track.releaseDate}</p>
    {track.note && <p class="track-note">{track.note}</p>}
    <div class="player-actions">
      <button
        class="action-button"
        id="load-featured-player"
        type="button"
        data-player-url={playerUrl}
        data-track-title={track.title}
        aria-controls="featured-player-embed"
        aria-expanded="false"
      >
        <span aria-hidden="true">▶</span> Play latest track
      </button>
      <a class="action-button action-button--ghost" href={track.url} target="_blank" rel="noreferrer">Open SoundCloud <span aria-hidden="true">↗</span></a>
    </div>
  </div>
  <div class="player-embed" id="featured-player-embed" hidden aria-live="polite"></div>
</section>

<style>
  .featured-player {
    display: grid;
    grid-template-columns: minmax(10rem, 18rem) minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(112deg, color-mix(in srgb, var(--accent) 12%, transparent), transparent 56%),
      var(--surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .player-artwork {
    position: relative;
    min-height: 18rem;
    overflow: hidden;
  }

  .player-artwork::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 42%, color-mix(in srgb, var(--background0) 72%, transparent));
  }

  .player-artwork img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .player-artwork span {
    position: absolute;
    z-index: 1;
    inset: auto auto 0.9rem 1rem;
    color: white;
    font: 700 0.7rem/1 var(--font-display);
    letter-spacing: 0.12em;
  }

  .player-copy {
    min-width: 0;
    display: grid;
    align-content: center;
    justify-items: start;
    padding: clamp(1.25rem, 4vw, 3rem);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-soft);
    font: 700 0.75rem/1.2 var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin-block: 0.75rem 0;
    font-size: clamp(2.3rem, 7vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.07em;
  }

  .track-meta {
    margin-block: 0.9rem 0;
    color: var(--foreground2);
    font: 0.8rem/1.4 var(--font-display);
  }

  .track-note {
    margin-block: 0.8rem 0;
    color: var(--foreground1);
  }

  .player-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding-block-start: 1.35rem;
  }

  .player-embed {
    grid-column: 1 / -1;
    border-block-start: 1px solid var(--border-subtle);
    background: var(--background0);
  }

  .player-embed :global(iframe) {
    display: block;
    width: 100%;
    height: min(28rem, 60vw);
    min-height: 20rem;
    border: 0;
  }

  @media (max-width: 680px) {
    .featured-player {
      grid-template-columns: 1fr;
    }

    .player-artwork {
      min-height: 0;
      aspect-ratio: 1;
    }

    .player-copy {
      padding: 1rem;
    }

    .player-actions > * {
      flex: 1 1 100%;
    }

    .player-embed :global(iframe) {
      height: 25rem;
    }
  }
</style>
