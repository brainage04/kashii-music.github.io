---
import type { Track } from '../data/tracks';

export interface Props {
  track: Track;
  priority?: boolean;
  index?: number;
}

const { track, priority = false, index } = Astro.props;
---

<article class="track-card" box-="square">
  <a class="track-artwork" href={track.url} target="_blank" rel="noreferrer" aria-label={`Listen to ${track.title} on SoundCloud`}>
    <img
      src={track.artwork}
      alt={`Artwork for ${track.title}`}
      width="500"
      height="500"
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
    />
    <span class="play-mark" aria-hidden="true">▶</span>
    {index !== undefined && <span class="track-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>}
  </a>
  <div class="track-body">
    <div class="track-meta">
      <span class="site-badge" is-="badge">{track.format}</span>
      <span>{track.genre}</span>
      <span>{track.year}</span>
    </div>
    <h2><a href={track.url} target="_blank" rel="noreferrer">{track.title}</a></h2>
    {track.note && <p>{track.note}</p>}
    <a class="track-link" href={track.url} target="_blank" rel="noreferrer">
      Play on SoundCloud <span aria-hidden="true">↗</span>
    </a>
  </div>
</article>

<style>
  .track-card {
    min-width: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    border-color: var(--panel-border);
    background: var(--panel-bg);
    box-shadow: var(--panel-shadow);
    overflow: hidden;
    transition: translate 360ms cubic-bezier(0.2, 0.7, 0.2, 1), border-color 360ms ease, box-shadow 360ms ease;
  }

  .track-card:hover {
    translate: 0 -0.25rem;
    border-color: color-mix(in srgb, var(--accent) 72%, var(--foreground2));
  }

  .track-artwork {
    position: relative;
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--background2);
  }

  .track-artwork::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, color-mix(in srgb, var(--background0) 68%, transparent));
  }

  .track-artwork img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: scale 520ms cubic-bezier(0.2, 0.7, 0.2, 1), filter 520ms ease;
  }

  .track-card:hover img {
    scale: 1.035;
    filter: saturate(1.1);
  }

  .play-mark {
    position: absolute;
    z-index: 2;
    inset: 50% auto auto 50%;
    translate: -50% -50%;
    display: grid;
    place-items: center;
    width: 3.25rem;
    aspect-ratio: 1;
    padding-inline-start: 0.15rem;
    border: 1px solid color-mix(in srgb, white 72%, transparent);
    background: color-mix(in srgb, var(--background0) 62%, transparent);
    color: white;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 320ms ease, scale 320ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .track-card:hover .play-mark,
  .track-artwork:focus-visible .play-mark {
    opacity: 1;
    scale: 1.05;
  }

  .track-index {
    position: absolute;
    z-index: 2;
    inset: auto auto 0.65rem 0.75rem;
    color: white;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }

  .track-body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem;
  }

  .track-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.7rem;
    color: var(--foreground2);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  h2 {
    margin-block: 0.8rem 0;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.15;
  }

  h2 a {
    color: var(--foreground0);
    text-decoration-thickness: 1px;
  }

  p {
    margin-block: 0.7rem 0;
    color: var(--foreground1);
    font-size: 0.9rem;
  }

  .track-link {
    margin-block-start: auto;
    padding-block-start: 1rem;
    color: var(--accent-soft);
    font-size: 0.86rem;
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .track-card,
    .track-artwork img,
    .play-mark {
      transition: none;
    }
  }
</style>
