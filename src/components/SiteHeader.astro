---
import { withBase } from '../lib/withBase';
import { siteConfig } from '../site.config';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  if (href.includes('#') || href.startsWith('http') || href.startsWith('mailto:')) return false;
  const targetPath = withBase(href).replace(/\/$/, '') || '/';
  return currentPath === targetPath;
};
---

<header class="site-header">
  <nav aria-label="Primary navigation">
    <a class="wordmark" href={withBase('/')} aria-label="kashii home">
      <span aria-hidden="true">K</span>
      <strong>kashii</strong><small>.wav</small>
    </a>

    <div class="nav-links">
      {siteConfig.navItems.map((item) => (
        <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined} data-active={isActive(item.href) ? 'true' : undefined}>
          {item.label}
        </a>
      ))}
    </div>

    <a class="listen-link" href={siteConfig.soundCloudUrl} target="_blank" rel="noreferrer">
      SoundCloud <span aria-hidden="true">↗</span>
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 10;
    border-block-end: 1px solid color-mix(in srgb, var(--foreground2) 28%, transparent);
    background: color-mix(in srgb, var(--background0) 88%, transparent);
    backdrop-filter: blur(16px);
  }

  nav {
    width: min(100% - 1.5rem, var(--site-width));
    min-height: 4.25rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.25rem;
  }

  .wordmark {
    display: inline-flex;
    width: fit-content;
    align-items: baseline;
    gap: 0.1rem;
    color: var(--foreground0);
    text-decoration: none;
  }

  .wordmark > span {
    display: grid;
    place-items: center;
    width: 1.75rem;
    aspect-ratio: 1;
    margin-inline-end: 0.4rem;
    border: 1px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 13%, transparent);
    color: var(--accent-soft);
    font-weight: 800;
  }

  .wordmark strong {
    letter-spacing: -0.04em;
  }

  .wordmark small {
    color: var(--foreground2);
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .nav-links a,
  .listen-link {
    color: var(--foreground1);
    font-size: 0.82rem;
    letter-spacing: 0.055em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 150ms ease;
  }

  .nav-links a {
    position: relative;
    padding-block: 1.5rem;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    inset: auto 0 0.9rem;
    height: 1px;
    background: var(--accent);
    scale: 0 1;
    transition: scale 150ms ease;
  }

  .nav-links a:hover,
  .nav-links a[data-active='true'],
  .listen-link:hover {
    color: var(--foreground0);
  }

  .nav-links a:hover::after,
  .nav-links a[data-active='true']::after {
    scale: 1 1;
  }

  .listen-link {
    justify-self: end;
    padding: 0.55rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--foreground2) 44%, transparent);
  }

  .listen-link:hover {
    border-color: var(--accent);
  }

  @media (max-width: 720px) {
    nav {
      grid-template-columns: 1fr auto;
      min-height: auto;
      padding-block: 0.75rem;
    }

    .nav-links {
      grid-row: 2;
      grid-column: 1 / -1;
      justify-content: space-between;
      border-block-start: 1px solid color-mix(in srgb, var(--foreground2) 20%, transparent);
    }

    .nav-links a {
      padding-block: 0.8rem 0.25rem;
    }

    .nav-links a::after {
      inset-block-end: -0.15rem;
    }
  }

  @media (max-width: 380px) {
    .wordmark small {
      display: none;
    }
  }
</style>
