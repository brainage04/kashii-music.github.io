---
import { withBase } from '../lib/withBase';
import { siteConfig } from '../site.config';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  if (href.includes('#') || href.startsWith('http') || href.startsWith('mailto:')) return false;
  const targetPath = withBase(href).replace(/\/$/, '') || '/';
  return currentPath === targetPath;
};
---

<header class="site-header">
  <nav aria-label="Primary navigation">
    <div class="nav-links">
      {siteConfig.navItems.map((item) => (
        <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined} data-active={isActive(item.href) ? 'true' : undefined}>
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 10;
    border-block-end: 1px solid color-mix(in srgb, var(--foreground2) 28%, transparent);
    background: var(--background0);
  }

  nav {
    width: min(100% - 1.5rem, var(--site-width));
    margin-inline: auto;
    display: flex;
    justify-content: center;
    padding-block: clamp(0.65rem, 1.4vw, 0.85rem);
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem clamp(1.55rem, 4vw, 2.7rem);
  }

  .nav-links a {
    color: var(--foreground1);
    border-block-end: 2px solid transparent;
    padding-block: 0.2rem;
    text-decoration: none;
    transition: color 180ms ease, border-color 180ms ease;
  }

  .nav-links a:hover,
  .nav-links a[data-active='true'] {
    color: var(--foreground0);
    border-block-end-color: var(--accent);
  }

  @media (max-width: 520px) {
    nav {
      width: min(100% - 1rem, var(--site-width));
      padding-block: 0.25rem;
    }

    .nav-links {
      width: 100%;
      justify-content: space-between;
      gap: 0.4rem clamp(0.65rem, 4vw, 1rem);
    }

    .nav-links a {
      display: inline-flex;
      min-height: 2.75rem;
      align-items: center;
    }
  }
</style>
