---
export interface Props {
  title?: string;
  class?: string;
  id?: string;
  shear?: 'top' | 'bottom' | 'both' | 'none';
}

const { title, class: className, id, shear = 'top' } = Astro.props;
const shearAttribute = shear === 'none' ? undefined : shear;
---

<section id={id} class:list={['terminal-panel', className]} box-="square" shear-={shearAttribute}>
  {title && (
    <div class="panel-header">
      <h2>{title}</h2>
    </div>
  )}
  <slot />
</section>
