---
import { Image } from 'astro:assets';
import { siteConfig } from '../site.config';
import { withBase } from '../lib/withBase';

const discordProfileUrl = 'https://discord.com/users/576348645742608387';
---

<section class="profile-card terminal-panel" box-="square" shear-="top">
  <Image
    class="avatar"
    src={withBase('/kashii-avatar.webp')}
    alt="kashii's Discord profile artwork"
    width="749"
    height="749"
    loading="eager"
    fetchpriority="high"
  />
  <div class="profile-copy">
    <div class="name-row">
      <h1>kashii</h1>
      <div class="socials" aria-label="Social profiles">
        <a href={siteConfig.soundCloudUrl} title="SoundCloud" aria-label="SoundCloud" target="_blank" rel="noreferrer">
          <img src={withBase('/assets/socials/soundcloud.svg')} alt="" width="24" height="24" />
        </a>
        <a href={discordProfileUrl} title="Discord" aria-label="Discord" target="_blank" rel="noreferrer">
          <img src={withBase('/assets/socials/discord.png')} alt="" width="619" height="469" />
        </a>
      </div>
    </div>
    <p>I’m a music producer based in Brisbane, Queensland, Australia who makes EDM and pop music.</p>
    <p>I’m open for <a href={withBase('/commissions/')}>commissions</a>.</p>
  </div>
</section>

<style>
  .profile-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 2.25rem);
    align-items: center;
    padding: clamp(1.65rem, 2.5vw, 2rem);
  }

  .avatar {
    width: clamp(6rem, 18vw, 10rem);
    aspect-ratio: 1;
    object-fit: cover;
    image-rendering: auto;
  }

  .profile-copy {
    display: grid;
    gap: 0.55rem;
    line-height: 1.35;
  }

  .name-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.45rem;
    align-items: center;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  p {
    margin: 0;
    color: var(--foreground1);
  }

  .socials {
    --social-icon-height: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    line-height: 0;
  }

  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    min-height: var(--social-icon-height);
  }

  .socials img {
    display: block;
    width: auto;
    height: var(--social-icon-height);
    max-width: none;
    object-fit: contain;
    filter: grayscale(1) brightness(1.8);
    opacity: 0.78;
    transition: filter 150ms ease, opacity 150ms ease;
  }

  .socials a:hover img {
    filter: grayscale(1) brightness(2.2);
    opacity: 1;
  }

  .profile-copy > p a {
    color: var(--accent-soft);
  }

  @media (max-width: 620px) {
    .profile-card {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      padding: 1.15rem;
    }

    .avatar {
      justify-self: center;
    }

    .profile-card,
    .name-row,
    .socials {
      justify-content: center;
    }

    .profile-copy {
      max-width: 34ch;
      margin-inline: auto;
      text-align: center;
    }

    h1 {
      font-size: clamp(1.5rem, 8vw, 2rem);
    }
  }
</style>
