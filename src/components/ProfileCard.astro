---
import { Image } from 'astro:assets';
import { siteConfig } from '../site.config';
import { withBase } from '../lib/withBase';

const discordProfileUrl = 'https://discord.com/users/576348645742608387';
---

<section class="profile-card" aria-labelledby="profile-title">
  <div class="avatar-frame">
    <Image
      class="avatar"
      src={withBase('/kashii-avatar.webp')}
      alt="kashii's Discord profile artwork"
      width="749"
      height="749"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="profile-copy">
    <p class="eyebrow">EDM + pop production</p>
    <div class="name-row">
      <h1 id="profile-title">kashii</h1>
      <div class="socials" aria-label="Social profiles">
        <a href={siteConfig.soundCloudUrl} title="SoundCloud" aria-label="SoundCloud" target="_blank" rel="noreferrer">
          <img src={withBase('/assets/socials/soundcloud.svg')} alt="" width="24" height="24" />
        </a>
        <a href={discordProfileUrl} title="Discord" aria-label="Discord" target="_blank" rel="noreferrer">
          <img src={withBase('/assets/socials/discord.png')} alt="" width="619" height="469" />
        </a>
      </div>
    </div>
    <p class="lead">Music producer in Brisbane making energetic electronic tracks, pop production and custom work for artists.</p>
    <p class="availability"><span aria-hidden="true"></span> Open for commissions</p>
    <div class="hero-actions">
      <a class="action-button" href={withBase('/projects/')}>Listen to tracks <span aria-hidden="true">→</span></a>
      <a class="action-button action-button--ghost" href={withBase('/commissions/')}>Book a commission</a>
    </div>
  </div>
</section>

<style>
  .profile-card {
    display: grid;
    grid-template-columns: minmax(7rem, 11rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(110deg, color-mix(in srgb, var(--accent) 9%, transparent), transparent 52%),
      var(--surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .avatar-frame {
    position: relative;
    padding: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--border-subtle));
    background: color-mix(in srgb, var(--accent) 8%, var(--background0));
  }

  .avatar {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }


  .profile-copy {
    min-width: 0;
    display: grid;
    gap: 0.75rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-soft);
    font: 700 0.75rem/1.2 var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .name-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1.2rem;
    align-items: center;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
  }

  .lead {
    max-width: 58ch;
    margin: 0;
    color: var(--foreground1);
    font-size: clamp(1rem, 1.5vw, 1.12rem);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    color: var(--accent-soft);
    font: 700 0.78rem/1.2 var(--font-display);
    text-transform: uppercase;
  }

  .availability span {
    width: 0.55rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--accent-soft);
    box-shadow: 0 0 0.8rem color-mix(in srgb, var(--accent-soft) 72%, transparent);
  }

  .socials {
    --social-icon-height: 21px;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    line-height: 0;
  }

  .socials a {
    display: inline-flex;
    min-width: 1.7rem;
    min-height: 1.7rem;
    align-items: center;
    justify-content: center;
  }

  .socials img {
    display: block;
    width: auto;
    height: var(--social-icon-height);
    max-width: none;
    object-fit: contain;
    filter: grayscale(1) brightness(1.8);
    opacity: 0.8;
    transition: filter 160ms ease, opacity 160ms ease, scale 160ms ease;
  }

  .socials a:hover img {
    filter: grayscale(1) brightness(2.3);
    opacity: 1;
    scale: 1.06;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding-block-start: 0.35rem;
  }

  @media (max-width: 680px) {
    .profile-card {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .avatar-frame {
      width: min(10rem, 48vw);
      justify-self: center;
    }

    .profile-copy,
    .name-row,
    .socials,
    .hero-actions {
      justify-content: center;
    }

    .profile-copy {
      text-align: center;
    }

    .lead {
      margin-inline: auto;
    }
  }

  @media (max-width: 420px) {
    .hero-actions > a {
      flex: 1 1 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .socials img {
      transition: none;
    }
  }
</style>
