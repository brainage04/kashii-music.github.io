---
import { siteConfig } from '../site.config';

const year = new Date().getFullYear();
const sourceUrl = import.meta.env.PUBLIC_SOURCE_URL || 'https://github.com/brainage04/kashii-music.github.io';
---

<footer class="site-footer">
  <div class="footer-inner">
    <span>© {year} <a href={siteConfig.soundCloudUrl} target="_blank" rel="noreferrer">kashii</a></span>
    <span>Made with <a href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a> + <a href="https://webtui.ironclad.sh/" target="_blank" rel="noreferrer">WebTUI</a></span>
    <a href={sourceUrl} target="_blank" rel="noreferrer">Source code</a>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--foreground2);
    color: var(--foreground2);
  }

  .footer-inner {
    width: min(100% - 1rem, var(--site-footer-width));
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    padding-block: 1rem;
  }

  a {
    color: var(--foreground1);
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent-soft);
  }
  @media (max-width: 520px) {
    .footer-inner {
      display: grid;
      justify-items: center;
      justify-content: center;
      text-align: center;
    }
  }

</style>
