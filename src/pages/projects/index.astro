---
import FeaturedPlayer from '../../components/FeaturedPlayer.astro';
import TrackCard from '../../components/TrackCard.astro';
import { tracks } from '../../data/tracks';
import SiteLayout from '../../layouts/SiteLayout.astro';

const latestTrack = tracks[0]!;
const originalTracks = tracks.filter((track) => track.format === 'Original');
const reinterpretations = tracks.filter((track) => track.format !== 'Original');
const trackIndex = (track: (typeof tracks)[number]) => tracks.indexOf(track);
---

<SiteLayout
  title="Music"
  description="Listen to my electronic tracks, flips and covers."
  image={latestTrack.artwork}
>
  <div class="music-stack">
    <FeaturedPlayer track={latestTrack} />

    <section class="catalogue-intro" aria-labelledby="catalogue-title">
      <p class="eyebrow">2025—2026</p>
      <div>
        <h2 id="catalogue-title">The catalogue</h2>
        <p>{tracks.length} public uploads spanning original electronic music, a sample flip and a cover.</p>
      </div>
    </section>

    <section id="originals" class="track-section" aria-labelledby="originals-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Original work</p>
          <h2 id="originals-title">Original tracks</h2>
        </div>
        <p>{originalTracks.length} uploads</p>
      </div>
      <div class="track-grid">
        {originalTracks.map((track) => {
          const index = trackIndex(track);
          return <TrackCard track={track} index={index} priority={index < 3} />;
        })}
      </div>
    </section>

    <section id="flips-and-covers" class="track-section" aria-labelledby="reinterpretations-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Reinterpretations</p>
          <h2 id="reinterpretations-title">Flips and covers</h2>
        </div>
        <p>{reinterpretations.length} uploads</p>
      </div>
      <div class="track-grid track-grid--two">
        {reinterpretations.map((track) => {
          const index = trackIndex(track);
          return <TrackCard track={track} index={index} priority={index < 3} />;
        })}
      </div>
    </section>
  </div>

  <script src="../../scripts/music.ts"></script>
</SiteLayout>

<style>
  .music-stack {
    display: grid;
    gap: clamp(4rem, 10vw, 7rem);
  }

  .catalogue-intro {
    display: grid;
    grid-template-columns: minmax(7rem, 0.3fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
    padding-block: 1rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-soft);
    font: 700 0.75rem/1.2 var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .catalogue-intro > div {
    display: grid;
    gap: 0.8rem;
  }

  .catalogue-intro h2,
  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.9rem, 5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .catalogue-intro > div > p {
    max-width: 58ch;
    margin: 0;
    color: var(--foreground1);
    font-size: 1.05rem;
  }

  .track-section {
    scroll-margin-block-start: 5rem;
  }

  .section-heading > div {
    display: grid;
    gap: 0.45rem;
  }

  .track-grid--two {
    width: min(100%, calc((100% - 1.35rem) * 0.667));
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .track-grid--two {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .catalogue-intro {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .track-grid--two {
      grid-template-columns: 1fr;
    }
  }
</style>
