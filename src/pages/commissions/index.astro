---
import { services } from '../../data/services';
import { soundCloudProfile } from '../../data/tracks';
import SiteLayout from '../../layouts/SiteLayout.astro';

const discordProfileUrl = 'https://discord.com/users/576348645742608387';
const faqs = [
  {
    question: 'What should I send?',
    answer: 'A short goal, two or three references, your budget, deadline and anything already recorded. Voice memos and rough demos are useful.',
  },
  {
    question: 'Are the listed prices final?',
    answer: 'They are starting prices in AUD. The final quote reflects scope, turnaround and intended usage, and is confirmed before work starts.',
  },
  {
    question: 'Who owns the finished music?',
    answer: 'Usage rights vary by service. The agreed licence, credits and permitted use will be written into the quote before production begins.',
  },
  {
    question: 'How long will it take?',
    answer: 'Timing depends on the project and my current queue. Include your deadline so I can confirm availability up front.',
  },
  {
    question: 'How does payment work?',
    answer: 'Payments are arranged through a parent or guardian. Half is due before work starts, and the other half is due after final approval but before the finished files are delivered. Prices and invoices are in AUD; international clients may be charged a conversion fee by their payment provider.',
  },
  {
    question: 'What is the refund policy?',
    answer: 'If I can’t complete the agreed project, the up-front payment will be refunded. If you cancel after work starts, the up-front payment is not refundable because it covers work already completed.',
  },
] as const;
---

<SiteLayout
  title="Commissions"
  description="Music production commissions for custom beats, mixing, beat licences and full song production."
>
  <div class="commissions-page">
    <header class="commissions-hero">
      <h1>Commissions</h1>
      <p>Pick what’s closest to what you need, then send me the details and I’ll confirm the final price before I start. Starting prices are in AUD.</p>
    </header>

    <section id="services" class="services-section" aria-labelledby="pricing-title">
      <div class="section-heading">
        <h2 id="pricing-title">Choose a service</h2>
      </div>

      <div class="pricing-grid">
        {services.map((service) => (
          <article class="price-card" id={service.id}>
            <div class="price-card__header">
              <h3>{service.name}</h3>
              <p class="price"><small>from</small> {service.price}</p>
            </div>
            <p class="summary">{service.summary}</p>
            <ul>
              {service.includes.map((item) => <li>{item}</li>)}
            </ul>
            <a class="action-button service-action" href="#contact" data-service={service.name}>Ask about this service <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </section>

    <section class="workflow-section" aria-labelledby="workflow-title">
      <div class="section-heading">
        <h2 id="workflow-title">How commissions work</h2>
      </div>
      <ol class="flow-list">
        <li><strong>01</strong><div><h3>Send</h3><p>Use the contact details below to send me a short project brief.</p></div></li>
        <li><strong>02</strong><div><h3>Quote</h3><p>Scope, price, revisions, rights and timing are confirmed in writing.</p></div></li>
        <li><strong>03</strong><div><h3>Create</h3><p>A first pass is produced and shared at the agreed review point.</p></div></li>
        <li><strong>04</strong><div><h3>Finish</h3><p>Feedback is applied and the approved files are delivered.</p></div></li>
      </ol>
    </section>

    <section id="contact" class="contact-section" aria-labelledby="contact-title">
      <div class="contact-primary">
        <h2 id="contact-title">Contact</h2>
        <p>Discord is the best way to reach me. You can also use my SoundCloud profile.</p>
        <a class="action-button contact-action" href={discordProfileUrl} target="_blank" rel="noreferrer">Message on Discord <span aria-hidden="true">↗</span></a>
        <dl>
          <div><dt>Discord</dt><dd>helpimdead111</dd></div>
          <div><dt>Also on</dt><dd><a href={soundCloudProfile} target="_blank" rel="noreferrer">SoundCloud ↗</a></dd></div>
        </dl>
      </div>

      <div class="brief-tools">
        <details>
          <summary>View message template</summary>
          <div class="details-body">
            <div class="details-heading">
              <p>Copy this and replace the bracketed details.</p>
              <button type="button" id="copy-template">Copy template</button>
            </div>
            <pre id="message-template">Hi, I’m [your name].

Service: [e.g. custom beat]
Project: [what you want made]
Reference links: [two or three songs with a similar sound]
Budget: [your budget in AUD]
Deadline: [the date you need it by]
Intended use: [e.g. Spotify release, YouTube video or personal use]

Anything else I should know: [vocals, stems or other useful details]</pre>
            <p id="contact-status" role="status" aria-live="polite"></p>
          </div>
        </details>

        <details>
          <summary>View an example brief</summary>
          <div class="details-body">
            <pre>Hi, I’m Alex.

Service: Custom beat
Project: A fast electronic track for a vocal single
Reference links: Two SoundCloud or Spotify track URLs
Budget: $180
Deadline: 20 September 2026
Intended use: Spotify and YouTube release

Anything else I should know: I have the vocals recorded and would also like an instrumental version.</pre>
          </div>
        </details>
      </div>
    </section>

    <section class="faq-section" aria-labelledby="faq-title">
      <div class="section-heading">
        <h2 id="faq-title">Q&A</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </div>

  <script src="../../scripts/contact.ts"></script>
</SiteLayout>

<style>
  .commissions-page {
    display: grid;
    gap: clamp(4.5rem, 11vw, 8rem);
  }

  .commissions-hero {
    display: grid;
    justify-items: start;
    gap: 1rem;
    padding-block: clamp(1rem, 5vw, 3rem);
  }


  .commissions-hero h1 {
    max-width: 14ch;
    margin: 0;
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.88;
    letter-spacing: -0.075em;
  }

  .commissions-hero > p {
    max-width: 62ch;
    margin: 0;
    color: var(--foreground1);
    font-size: clamp(1rem, 2vw, 1.15rem);
  }



  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.9rem, 5vw, 3rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .price-card {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(1.1rem, 3vw, 1.6rem);
    border-block-start: 1px solid var(--border-strong);
    background: var(--surface-raised);
    box-shadow: var(--shadow-soft);
    transition: translate 180ms ease, border-color 180ms ease;
  }

  .price-card:hover,
  .price-card:focus-within {
    translate: 0 -0.2rem;
    border-block-start-color: var(--accent-soft);
  }

  .price-card__header {
    width: 100%;
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }

  .price-card h3 {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    letter-spacing: -0.04em;
  }

  .price {
    display: grid;
    justify-items: end;
    margin: 0;
    color: var(--accent-soft);
    font: 800 clamp(2rem, 5vw, 3rem)/0.9 var(--font-display);
    letter-spacing: -0.07em;
    white-space: nowrap;
  }

  .price small {
    color: var(--foreground2);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .summary {
    margin-block: 1rem 0;
    color: var(--foreground1);
  }

  .price-card ul {
    display: grid;
    gap: 0.45rem;
    margin-block: 1rem;
    padding: 0;
    list-style: none;
    color: var(--foreground1);
    font-size: 0.9rem;
  }

  .price-card li::before {
    content: '+ ';
    color: var(--accent-soft);
    font-family: var(--font-display);
  }


  .service-action {
    width: 100%;
  }

  .flow-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    padding: 1px;
    list-style: none;
    background: var(--border-subtle);
  }

  .flow-list li {
    min-width: 0;
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    background: var(--surface);
  }

  .flow-list strong {
    color: var(--accent-soft);
    font: 700 1.35rem/1 var(--font-display);
  }

  .flow-list h3,
  .flow-list p {
    margin: 0;
  }

  .flow-list h3 {
    margin-block-end: 0.45rem;
    font-size: 1rem;
  }

  .flow-list p {
    color: var(--foreground1);
    font-size: 0.9rem;
  }

  .contact-section {
    display: grid;
    grid-template-columns: minmax(16rem, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    padding: clamp(1.2rem, 4vw, 2.4rem);
    border-inline-start: 3px solid var(--accent-soft);
    background: var(--surface-raised);
    box-shadow: var(--shadow-soft);
    scroll-margin-block-start: 5rem;
  }

  .contact-primary {
    display: grid;
    align-content: start;
    justify-items: start;
    gap: 0.9rem;
  }

  .contact-primary h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1;
  }

  .contact-primary > p:nth-child(3) {
    margin: 0;
    color: var(--foreground1);
  }

  .contact-action {
    width: 100%;
    margin-block: 0.5rem;
  }

  .contact-primary dl {
    width: 100%;
    display: grid;
    gap: 0;
    margin: 0;
    border-block-end: 1px solid var(--border-subtle);
  }

  .contact-primary dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.75rem;
    border-block-start: 1px solid var(--border-subtle);
  }

  .contact-primary dt {
    color: var(--foreground2);
    font: 0.72rem/1.3 var(--font-display);
    text-transform: uppercase;
  }

  .contact-primary dd {
    margin: 0;
    font-weight: 700;
  }

  .brief-tools {
    min-width: 0;
    display: grid;
    align-content: start;
    gap: 0.7rem;
  }

  .brief-tools details,
  .faq-list details {
    border-block-start: 1px solid var(--border-subtle);
    background: var(--surface);
  }

  .brief-tools summary,
  .faq-list summary {
    cursor: pointer;
    padding: 1rem;
    color: var(--foreground0);
    font: 700 0.9rem/1.3 var(--font-display);
  }

  .brief-tools details[open] summary,
  .faq-list details[open] summary {
    color: var(--accent-soft);
  }

  .details-body {
    padding: 0 1rem 1rem;
  }

  .details-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-block-end: 0.8rem;
  }

  .details-heading p {
    margin: 0;
    color: var(--foreground1);
    font-size: 0.88rem;
  }

  #copy-template {
    border: 0;
    background: transparent;
    color: var(--accent-soft);
    padding: 0;
    font: 700 0.8rem/1.2 var(--font-display);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  pre {
    max-width: 100%;
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
    background: var(--background0);
    color: var(--foreground1);
    font: 0.78rem/1.5 var(--font-display);
    white-space: pre-wrap;
  }

  #contact-status {
    min-height: 1.2rem;
    margin-block: 0.6rem 0;
    color: var(--accent-soft);
    font-size: 0.8rem;
  }

  .faq-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .faq-list details > p {
    margin: 0;
    padding: 0 1rem 1rem;
    color: var(--foreground1);
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .contact-section {
      grid-template-columns: 1fr;
    }

    .flow-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .pricing-grid,
    .faq-list {
      grid-template-columns: 1fr;
    }

    .flow-list {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0;
      background: transparent;
    }

    .flow-list li {
      grid-template-columns: auto minmax(0, 1fr);
      border-inline-start: 2px solid var(--border-subtle);
    }

    .flow-list li:hover {
      border-inline-start-color: var(--accent-soft);
    }
  }

  @media (max-width: 420px) {
    .price-card__header {
      display: grid;
    }

    .price {
      justify-items: start;
    }

    .contact-section {
      padding: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .price-card {
      transition: none;
    }
  }
</style>
