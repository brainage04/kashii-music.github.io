---
import PageHeader from '../../components/PageHeader.astro';
import TerminalPanel from '../../components/TerminalPanel.astro';
import { services } from '../../data/services';
import { soundCloudProfile } from '../../data/tracks';
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Commissions"
  description="My music production commission options and starter pricing, including custom instrumentals, beat licences, mixing and full production."
>
  <div class="site-stack commissions-stack">
    <PageHeader
      eyebrow="Commissions / Open"
      title="Production commissions."
      description="Choose a starting point and send me the details. I’ll confirm the scope and final quote before work begins. Introductory prices are listed in Australian dollars."
    />

    <section aria-labelledby="pricing-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Starter pricing</p>
          <h2 id="pricing-title">Choose a service</h2>
        </div>
        <p>All prices from · AUD</p>
      </div>

      <div class="pricing-grid">
        {services.map((service) => (
          <article class:list={['price-card', { 'price-card--featured': service.featured }]} box-="square">
            <div class="price-topline">
              <span>{service.id.toUpperCase().replaceAll('-', '_')}</span>
              {service.featured && <span class="site-badge" is-="badge">Most requested</span>}
            </div>
            <h3>{service.name}</h3>
            <p class="price"><small>from</small> {service.price}</p>
            <p class="summary">{service.summary}</p>
            <ul>
              {service.includes.map((item) => <li>{item}</li>)}
            </ul>
            <a href="#contact">Choose {service.name.toLowerCase()} <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>

      <p class="pricing-note">
        Final quotes depend on scope, deadline and intended usage. Any deliverables, revisions and usage rights are agreed in writing before work starts.
      </p>
    </section>

    <section aria-labelledby="workflow-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">How it works</p>
          <h2 id="workflow-title">How commissions work</h2>
        </div>
      </div>
      <ol class="flow-list">
        <li><strong>01 / Send</strong><p>Use the contact details below to send me a short project brief.</p></li>
        <li><strong>02 / Quote</strong><p>Scope, price, revisions, rights and timing are confirmed in writing.</p></li>
        <li><strong>03 / Create</strong><p>A first pass is produced and shared at the agreed review point.</p></li>
        <li><strong>04 / Finish</strong><p>Feedback is applied and the approved files are delivered.</p></li>
      </ol>
    </section>

    <TerminalPanel title="Contact" id="contact" class="contact-panel" shear="none">
      <div class="contact-grid">
        <div class="contact-copy">
          <p class="eyebrow">Contact</p>
          <h2>Send me the project details.</h2>
          <p>Discord is the best way to reach me. You can also use my SoundCloud profile.</p>

          <div class="contact-list">
            <div class="contact-row">
              <span>Discord</span>
              <strong>helpimdead111</strong>
              <button type="button" data-copy-text="helpimdead111" data-copy-label="Discord username">Copy</button>
            </div>
            <div class="contact-row">
              <span>SoundCloud</span>
              <strong>@kashii</strong>
              <a href={soundCloudProfile} target="_blank" rel="noreferrer">Open ↗</a>
            </div>
          </div>

          <div class="panel-actions">
            <a class="action-button action-button--ghost" href="https://discord.com/app" target="_blank" rel="noreferrer" is-="button">Open Discord ↗</a>
          </div>
        </div>

        <div class="message-template">
          <div class="template-heading">
            <div>
              <p class="eyebrow">Message template</p>
              <h3>Include the useful details</h3>
            </div>
            <button type="button" id="copy-template">Copy template</button>
          </div>
          <pre id="message-template">Hi, I’m [name].

Service:
Project:
Reference links:
Budget:
Deadline:
Intended use:

Anything else I should know:</pre>
          <p id="contact-status" role="status" aria-live="polite"></p>
        </div>
      </div>
    </TerminalPanel>

    <section aria-labelledby="faq-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Before you ask</p>
          <h2 id="faq-title">Quick answers</h2>
        </div>
      </div>
      <div class="faq-grid">
        <details open>
          <summary>What should I send?</summary>
          <p>A short goal, two or three references, your budget, deadline and anything already recorded. Voice memos and rough demos are useful.</p>
        </details>
        <details>
          <summary>Are the listed prices final?</summary>
          <p>They are starting prices in AUD. The final quote reflects scope, turnaround and intended usage, and is confirmed before work starts.</p>
        </details>
        <details>
          <summary>Who owns the finished music?</summary>
          <p>Usage rights vary by service. The agreed licence, credits and permitted use will be written into the quote before production begins.</p>
        </details>
        <details>
          <summary>How long will it take?</summary>
          <p>Timing depends on the project and my current queue. Include your real deadline so I can confirm availability up front.</p>
        </details>
      </div>
    </section>
  </div>

  <script src="../../scripts/contact.ts"></script>
</SiteLayout>

<style>
  .commissions-stack {
    gap: clamp(3rem, 7vw, 5.5rem);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .price-card {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-color: var(--panel-border);
    background: var(--panel-bg);
    padding: clamp(1.1rem, 3vw, 1.6rem);
    box-shadow: var(--panel-shadow);
  }

  .price-card--featured {
    border-color: color-mix(in srgb, var(--accent) 70%, var(--foreground2));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 55%),
      var(--panel-bg);
  }

  .price-topline {
    width: 100%;
    min-height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--foreground2);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .price-card h3 {
    margin-block: 1.15rem 0;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    letter-spacing: -0.04em;
  }

  .price {
    margin-block: 0.5rem 0;
    color: var(--accent-soft);
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.07em;
  }

  .price small {
    color: var(--foreground2);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .summary {
    margin-block: 0.9rem 0;
    color: var(--foreground1);
  }

  .price-card ul {
    display: grid;
    gap: 0.45rem;
    margin-block: 1rem 1.3rem;
    padding: 0;
    list-style: none;
    color: var(--foreground1);
    font-size: 0.86rem;
  }

  .price-card li::before {
    content: '+ ';
    color: var(--accent);
  }

  .price-card > a {
    margin-block-start: auto;
    color: var(--accent-soft);
    font-weight: 700;
  }

  .pricing-note {
    margin: 1rem 0 0;
    color: var(--foreground2);
    font-size: 0.8rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(1.5rem, 5vw, 4rem);
  }

  .contact-copy h2 {
    margin-block: 0.65rem 0;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .contact-copy > p:not(.eyebrow) {
    margin-block: 0.9rem 1.4rem;
    color: var(--foreground1);
  }

  .contact-list {
    margin-block-end: 1.25rem;
    border-block-end: 1px solid color-mix(in srgb, var(--foreground2) 30%, transparent);
  }

  .contact-row {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    padding-block: 0.85rem;
    border-block-start: 1px solid color-mix(in srgb, var(--foreground2) 30%, transparent);
  }

  .contact-row > span {
    color: var(--foreground2);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .contact-row strong {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .contact-row :is(button, a),
  #copy-template {
    border: 0;
    background: transparent;
    color: var(--accent-soft);
    padding: 0;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .message-template {
    min-width: 0;
    border: 1px solid var(--control-border);
    background: var(--background0);
    padding: 1rem;
  }

  .template-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .template-heading h3 {
    margin-block: 0.45rem 0;
  }

  .message-template pre {
    margin-block: 1rem 0;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--foreground2) 28%, transparent);
    background: var(--background1);
    color: var(--foreground1);
    font: inherit;
    font-size: 0.84rem;
    white-space: pre-wrap;
  }

  #contact-status {
    min-height: 1.25rem;
    margin-block: 0.65rem 0;
    color: var(--accent-green);
    font-size: 0.78rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    background: color-mix(in srgb, var(--foreground2) 28%, transparent);
  }

  details {
    background: var(--background1);
    padding: 1.1rem;
  }

  summary {
    cursor: pointer;
    color: var(--foreground0);
    font-weight: 700;
  }

  details p {
    margin-block: 0.8rem 0;
    color: var(--foreground1);
    font-size: 0.88rem;
  }

  @media (max-width: 700px) {
    .pricing-grid,
    .contact-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }

    .contact-row {
      grid-template-columns: 5.5rem minmax(0, 1fr) auto;
    }
  }
</style>
