---
import SiteLayout from '../layouts/SiteLayout.astro';
import { withBase } from '../lib/withBase';
---

<SiteLayout title="Not found" description="The requested kashii portfolio page could not be found.">
  <section class="not-found" box-="square">
    <h1>This track does not exist.</h1>
    <p>The page may have moved, or the link may be out of tune.</p>
    <div class="hero-actions">
      <a class="action-button" href={withBase('/')} is-="button">Return home</a>
      <a class="action-button action-button--ghost" href={withBase('/projects/')} is-="button">Browse music</a>
    </div>
  </section>
</SiteLayout>

<style>
  .not-found {
    min-height: min(38rem, calc(100vh - 14rem));
    display: grid;
    place-content: center;
    justify-items: start;
    border-color: var(--panel-border);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 45%),
      var(--panel-bg);
    padding: clamp(1.25rem, 6vw, 4rem);
    box-shadow: var(--panel-shadow);
  }


  h1 {
    max-width: 15ch;
    margin-block: 0;
    font-size: clamp(2rem, 6vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .not-found > p {
    margin-block: 1rem 1.5rem;
    color: var(--foreground1);
  }
</style>
