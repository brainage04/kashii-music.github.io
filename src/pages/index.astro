---
import TerminalPanel from '../components/TerminalPanel.astro';
import TrackCard from '../components/TrackCard.astro';
import { soundCloudProfile, tracks } from '../data/tracks';
import SiteLayout from '../layouts/SiteLayout.astro';
import { withBase } from '../lib/withBase';

const featuredTracks = tracks.filter((track) => track.featured).slice(0, 3);
const latestTrack = tracks[0]!;
const waveform = [28, 46, 72, 38, 84, 58, 92, 48, 68, 34, 78, 54, 88, 44, 64, 30, 72, 42, 82, 50, 66, 36, 74, 46];
---

<SiteLayout title="Home">
  <div class="site-stack home-stack">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="kicker-line">Independent electronic producer</p>
        <h1 id="hero-title">Turn the feeling <span>all the way up.</span></h1>
        <p class="hero-intro">
          Original production, hard-hitting electronic tracks and melodic ideas by <strong>kashii</strong>.
          Available for select artist projects and commissions.
        </p>
        <div class="hero-actions">
          <a class="action-button" href={withBase('/projects/')} is-="button">Hear the music <span aria-hidden="true">→</span></a>
          <a class="action-button action-button--ghost" href={withBase('/commissions/')} is-="button">Start a project</a>
        </div>
        <p class="availability"><span aria-hidden="true"></span> Open for commissions</p>
      </div>

      <div class="hero-player" box-="square">
        <div class="player-bar">
          <span>NOW_PLAYING</span>
          <span>01 / 05</span>
        </div>
        <a class="cover-link" href={latestTrack.url} target="_blank" rel="noreferrer" aria-label={`Play ${latestTrack.title} on SoundCloud`}>
          <img src={latestTrack.artwork} alt={`Artwork for ${latestTrack.title}`} width="500" height="500" fetchpriority="high" />
          <span class="cover-play" aria-hidden="true">▶</span>
        </a>
        <div class="waveform" aria-hidden="true">
          {waveform.map((level) => <i style={`--level: ${level}%`}></i>)}
        </div>
        <div class="player-meta">
          <div>
            <strong>{latestTrack.title}</strong>
            <span>kashii · {latestTrack.genre}</span>
          </div>
          <a href={latestTrack.url} target="_blank" rel="noreferrer" aria-label="Open Time Collapse on SoundCloud">↗</a>
        </div>
      </div>
    </section>

    <section class="signal-strip" aria-label="Production services">
      <span>Original production</span>
      <span>Custom instrumentals</span>
      <span>Mix & polish</span>
      <span>Electronic / Pop</span>
    </section>

    <TerminalPanel title="Artist profile" class="about-panel" shear="none">
      <div class="about-grid">
        <div>
          <p class="eyebrow">About kashii</p>
          <h2>Electronic music with a pulse.</h2>
        </div>
        <div class="about-copy">
          <p>
            kashii is an independent producer focused on high-energy electronic music, emotional melody and
            detailed sound design. The catalogue moves through original Dance & EDM tracks, sample flips and pop covers.
          </p>
          <p>
            Now taking on a small number of freelance projects: custom instrumentals, production, arrangement and final polish.
          </p>
          <a href={soundCloudProfile} target="_blank" rel="noreferrer">Follow the SoundCloud <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </TerminalPanel>

    <section aria-labelledby="featured-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="featured-title">Latest transmissions</h2>
        </div>
        <a href={withBase('/projects/')}>View all tracks <span aria-hidden="true">→</span></a>
      </div>
      <div class="track-grid">
        {featuredTracks.map((track, index) => <TrackCard track={track} index={index} priority={index === 0} />)}
      </div>
    </section>

    <section aria-labelledby="process-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Commission process</p>
          <h2 id="process-title">From reference to final bounce</h2>
        </div>
        <p>Simple, direct and collaborative.</p>
      </div>
      <ol class="flow-list">
        <li><strong>01 / Brief</strong><p>Share the idea, references, intended use and deadline.</p></li>
        <li><strong>02 / Direction</strong><p>Confirm the scope, price and creative lane before work starts.</p></li>
        <li><strong>03 / Build</strong><p>Production takes shape with a clear review point for feedback.</p></li>
        <li><strong>04 / Deliver</strong><p>Approve the final and receive the agreed high-quality exports.</p></li>
      </ol>
    </section>

    <section class="cta-panel" aria-labelledby="cta-title">
      <div>
        <p class="eyebrow">Need a sound?</p>
        <h2 id="cta-title">Bring the reference. Build something original.</h2>
        <p>Starter pricing is live. Final quotes are based on the brief.</p>
      </div>
      <a class="action-button" href={withBase('/commissions/')} is-="button">View commissions <span aria-hidden="true">→</span></a>
    </section>
  </div>
</SiteLayout>

<style>
  .home-stack {
    gap: clamp(3.5rem, 8vw, 7rem);
  }

  .hero {
    min-height: min(42rem, calc(100vh - 8rem));
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(19rem, 0.72fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .hero-copy {
    display: grid;
    justify-items: start;
    gap: 1.3rem;
  }

  h1 {
    max-width: 10ch;
    margin: 0;
    font-size: clamp(3.4rem, 8.4vw, 7.2rem);
    line-height: 0.84;
    letter-spacing: -0.085em;
    text-wrap: balance;
  }

  h1 span {
    display: block;
    color: var(--accent-soft);
    text-shadow: 0 0 3rem color-mix(in srgb, var(--accent) 28%, transparent);
  }

  .hero-intro {
    max-width: 58ch;
    margin: 0;
    color: var(--foreground1);
    font-size: clamp(1rem, 2vw, 1.16rem);
  }

  .hero-intro strong {
    color: var(--foreground0);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    color: var(--foreground2);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .availability span {
    width: 0.6rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 1rem color-mix(in srgb, var(--accent-green) 70%, transparent);
  }

  .hero-player {
    position: relative;
    min-width: 0;
    border-color: color-mix(in srgb, var(--accent) 54%, var(--foreground2));
    background: var(--background1);
    padding: clamp(0.75rem, 2vw, 1rem);
    box-shadow: 1.1rem 1.1rem 0 color-mix(in srgb, var(--accent) 8%, transparent), var(--panel-shadow);
  }

  .player-bar,
  .player-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .player-bar {
    padding-block-end: 0.7rem;
    color: var(--foreground2);
    font-size: 0.7rem;
    letter-spacing: 0.09em;
  }

  .cover-link {
    position: relative;
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--background2);
  }

  .cover-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 54%, color-mix(in srgb, var(--accent) 18%, transparent));
  }

  .cover-play {
    position: absolute;
    z-index: 2;
    inset: 50% auto auto 50%;
    translate: -50% -50%;
    display: grid;
    place-items: center;
    width: 4rem;
    aspect-ratio: 1;
    padding-inline-start: 0.2rem;
    border: 1px solid color-mix(in srgb, white 75%, transparent);
    border-radius: 50%;
    background: color-mix(in srgb, var(--background0) 62%, transparent);
    color: white;
    transition: scale 160ms ease, background 160ms ease;
  }

  .cover-link:hover .cover-play {
    scale: 1.08;
    background: color-mix(in srgb, var(--accent) 68%, transparent);
  }

  .waveform {
    height: 3.3rem;
    display: flex;
    align-items: center;
    gap: 3px;
    padding-block: 0.75rem 0.5rem;
  }

  .waveform i {
    flex: 1;
    height: var(--level);
    min-width: 2px;
    background: linear-gradient(to top, var(--accent), var(--accent-hot));
    opacity: 0.82;
  }

  .player-meta strong,
  .player-meta span {
    display: block;
  }

  .player-meta strong {
    line-height: 1.2;
  }

  .player-meta span {
    margin-block-start: 0.15rem;
    color: var(--foreground2);
    font-size: 0.76rem;
  }

  .player-meta > a {
    display: grid;
    place-items: center;
    width: 2.3rem;
    aspect-ratio: 1;
    border: 1px solid var(--control-border);
    text-decoration: none;
  }

  .signal-strip {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
    border-block: 1px solid color-mix(in srgb, var(--foreground2) 30%, transparent);
    color: var(--foreground2);
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .signal-strip span::before {
    content: '+ ';
    color: var(--accent);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: clamp(2rem, 7vw, 6rem);
  }

  .about-grid h2 {
    max-width: 12ch;
    margin-block: 0.8rem 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .about-copy p {
    margin-block: 0 1rem;
    color: var(--foreground1);
  }

  .about-copy a {
    color: var(--accent-soft);
    font-weight: 700;
  }

  @media (max-width: 850px) {
    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
    }

    .hero-player {
      width: min(100%, 28rem);
      justify-self: center;
    }

    .signal-strip {
      flex-wrap: wrap;
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .home-stack {
      gap: 3.5rem;
    }

    .hero {
      gap: 2.5rem;
    }

    h1 {
      font-size: clamp(3.25rem, 18vw, 5rem);
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
