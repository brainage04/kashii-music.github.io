---
import TerminalPanel from '../components/TerminalPanel.astro';
import TrackCard from '../components/TrackCard.astro';
import { soundCloudProfile, tracks } from '../data/tracks';
import SiteLayout from '../layouts/SiteLayout.astro';
import { withBase } from '../lib/withBase';

const featuredTracks = tracks.filter((track) => track.featured).slice(0, 3);
---

<SiteLayout title="Home">
  <div class="site-stack home-stack">

    <TerminalPanel title="Artist profile" class="about-panel" shear="none">
      <div class="about-grid">
        <div>
          <p class="eyebrow">About me</p>
          <h2>About my work.</h2>
        </div>
        <div class="about-copy">
          <p>
            I’m an independent producer focused on high-energy electronic music, emotional melody and
            detailed sound design. My catalogue includes original Dance & EDM tracks, sample flips and pop covers.
          </p>
          <p>
            I’m currently taking on a small number of freelance projects: custom instrumentals, production,
            arrangement and final polish.
          </p>
          <a href={soundCloudProfile} target="_blank" rel="noreferrer">Follow me on SoundCloud <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </TerminalPanel>

    <section class="signal-strip" aria-label="Production services">
      <span>Original production</span>
      <span>Custom instrumentals</span>
      <span>Mix & polish</span>
      <span>Electronic / Pop</span>
    </section>

    <section aria-labelledby="featured-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="featured-title">Recent tracks</h2>
        </div>
        <a href={withBase('/projects/')}>View all tracks <span aria-hidden="true">→</span></a>
      </div>
      <div class="track-grid">
        {featuredTracks.map((track, index) => <TrackCard track={track} index={index} priority={index === 0} />)}
      </div>
    </section>


    <section class="cta-panel" aria-labelledby="cta-title">
      <div>
        <p class="eyebrow">Commissions</p>
        <h2 id="cta-title">Production commissions are open.</h2>
        <p>View available services, starting prices and contact details.</p>
      </div>
      <a class="action-button" href={withBase('/commissions/')} is-="button">View pricing <span aria-hidden="true">→</span></a>
    </section>
  </div>
</SiteLayout>

<style>
  .home-stack {
    gap: clamp(2rem, 5vw, 4rem);
  }


  .signal-strip {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
    border-block: 1px solid color-mix(in srgb, var(--foreground2) 30%, transparent);
    color: var(--foreground2);
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .signal-strip span::before {
    content: '+ ';
    color: var(--accent);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: clamp(2rem, 7vw, 6rem);
  }

  .about-grid h2 {
    max-width: 12ch;
    margin-block: 0.8rem 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .about-copy p {
    margin-block: 0 1rem;
    color: var(--foreground1);
  }

  .about-copy a {
    color: var(--accent-soft);
    font-weight: 700;
  }

  @media (max-width: 850px) {

    .signal-strip {
      flex-wrap: wrap;
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .home-stack {
      gap: 3.5rem;
    }


    .about-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
